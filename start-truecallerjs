#!/bin/bash

checkNotification(){
    json_Data=`termux-notification-list`
    json_Length=`echo  $json_Data | jq length`
    status_code=1
    for ((j=0;j<=json_Length-1;j++));
    do
        package_Name=`echo  $json_Data | jq -r .[$j].packageName`
        if [[ $package_Name == "com.android.incallui" ]]
        then
               status_code=0
        fi
    done
    echo $status_code
}
echo -e "\033[1;32mStarting Truecallerjs....\033[0m"
echo -e "\033[1;32mStarted Truecallerjs at $(date)\033[0m"
while true ;
do
        jsonData=`termux-notification-list`
        jsonLength=`echo  $jsonData | jq length`
        for ((i=0;i<=jsonLength-1;i++));
        do
              packageName=`echo  $jsonData | jq -r .[$i].packageName`
              if [[ $packageName == "com.android.incallui" ]]
              then
                    phoneNumber=`echo $jsonData | jq -r .[$i].title`
                    truecallerData=`truecallerjs -s $phoneNumber`
                    echo $truecallerData
                    # echo "$(echo -e '$truecallerData' | jq empty > /dev/null 2>&1; echo $?)"
                    if [ $(echo -e '$truecallerData' | jq empty > /dev/null 2>&1; echo $?) -eq 0 ]; 
                    then
                         if [ -z  "`echo -e $truecallerData  | jq -r .data[0].name`" ]
                         then
                               if [ -z  "`echo -e $truecallerData  | jq -r .status`" ]
                               then
                                    data=`echo -e " Name      :  Unknown Name\nNumber  : $phoneNumber"`
                               else
                                    error=`echo -e $truecallerData  | jq -r .message`
                                    data=`echo -e " Name      :  Unknown Name\nNumber  : $phoneNumber\nError   :  $error"`
                               fi
                         else
                               name=`echo -e $truecallerData  | jq -r .data[0].name`
                               data=`echo -e " Name      :  $name\nNumber  : $phoneNumber"`

                         fi
                    else
                         if [[ $truecallerData ==  '""' ]];
                         then
                              content=`echo $jsonData | jq -r .[$i].content`
                              data=`echo -e " Name      :  $phoneNumber\nNumber  : $content"`
                         else
                              data=`echo -e " Name      :  Unknown Name\nNumber  : $phoneNumber\nError     :  $truecallerData"`
                         fi

                    fi
                    termux-notification -t TruecallerJS -c "$data" --button1 call --button1-action "termux-telephony-call $phoneNumber"
                    checkNotification
                    until [[ $status_code == 1 ]];
                    do
                          echo -e "\033[1;34mYou are on call...\033[0m"
                          sleep 10
                          checkNotification
                    done

              fi
        done
done
